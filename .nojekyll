<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sumbangan PASTI Kota Samarahan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body { font-family: sans-serif; background-color: #f1f5f9; }
        .hero-img { width: 100%; height: 250px; object-fit: cover; border-radius: 20px; }
    </style>
</head>
<body class="p-4">
    <div class="max-w-md mx-auto bg-white rounded-3xl shadow-lg overflow-hidden border border-slate-200">
        <div class="bg-green-700 p-6 text-white text-center">
            <h1 class="text-2xl font-bold uppercase italic">PASTI Kota Samarahan</h1>
            <p class="text-xs opacity-80 uppercase tracking-widest mt-1">Portal Sumbangan Rasmi</p>
        </div>

        <div class="p-6">
            <img src="https://lh3.googleusercontent.com/d/1Ms6jZACBkaJ1zPp2Kt5HqRhbO_MYtumH" class="hero-img mb-6 shadow-md" alt="Poster Infaq">

            <div class="space-y-4">
                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100">
                    <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">Maklumat Akaun</p>
                    <p class="font-bold text-slate-700">Co-opBank Pertama</p>
                    <p class="text-xl font-mono text-green-700 font-black">110321000625</p>
                </div>

                <a href="https://pastikotasamarahan.bcl.my/form/sumbangan-ramadan" target="_blank" class="block w-full bg-[#00adef] text-white text-center py-4 rounded-xl font-bold shadow-lg hover:bg-blue-500 transition-all uppercase text-sm">
                    Bayar Online (BCL/Billplz)
                </a>

                <a href="https://wa.me/60104264560?text=Saya%20ingin%20sahkan%20sumbangan%20PASTI" target="_blank" class="block w-full bg-green-600 text-white text-center py-4 rounded-xl font-bold shadow-lg hover:bg-green-700 transition-all uppercase text-sm">
                    Sahkan via WhatsApp
                </a>
            </div>
        </div>

        <div class="p-4 bg-slate-50 text-center">
            <p class="text-[9px] text-slate-400 font-bold uppercase tracking-widest">© 2026 PASTI KOTA SAMARAHAN</p>
        </div>
    </div>
</body>
</html>
